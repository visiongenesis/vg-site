  "alert_rules": [
    {
      "id": "deadline-30d",
      "name": "Quarterly deadline approaching",
      "condition": "outstanding_value > 0 AND days_to_deadline <= 30",
      "channel": "email",
      "template": "deadline-q-reminder"
    },
    {
      "id": "missed-quarterly",
      "name": "Member missed quarterly visit",
      "condition": "membership_active AND days_since_last_redemption > 90",
      "channel": "sms",
      "template": "membership-recapture"
    }
  ],
  "csv_import_mappings": {
