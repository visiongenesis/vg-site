      "description": "Aesthetic Record service log export",
      "expected_columns": [
        "client_id",
        "client_name",
        "visit_id",
        "service_date",
        "performed_by",
        "service_code",
        "service_name",
        "quantity",
        "amount_charged"
      ],
      "match_strategy": "client_id + service_date + service_name \u2192 match against outstanding package units"
    },
